# ============================================================
#  TravelTrace Flutter App — .gitignore
# ============================================================

# ── Miscellaneous ────────────────────────────────────────────
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# ── Editor / IDE ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ── Flutter / Dart / Pub ─────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# ── Generated files ───────────────────────────────────────────
*.g.dart
*.freezed.dart
*.mocks.dart

# ── Android build artifacts ───────────────────────────────────
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/.gradle/
/android/captures/
/android/local.properties    # Contains SDK path — machine-specific
**/android/**/gradle-wrapper.jar
**/android/**/*.iml
**/android/gradlew
**/android/gradlew.bat
**/android/**/GeneratedPluginRegistrant.java

# ── iOS build artifacts ───────────────────────────────────────
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/UserInterfaceState.xcuserstate
**/ios/.generated/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/Runner.xcworkspace/
Podfile.lock

# ── Web ───────────────────────────────────────────────────────
/web/

# ── Linux / Windows / macOS desktop ─────────────────────────
/linux/
/windows/
/macos/

# ── Symbolication / Obfuscation ──────────────────────────────
app.*.symbols
app.*.map.json

# ── Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
google-services.json          # Firebase config — contains API keys
GoogleService-Info.plist      # Firebase iOS config
